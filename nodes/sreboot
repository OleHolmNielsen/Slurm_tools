#!/usr/bin/env bash

# Slurm: use scontrol to reboot nodes
# NextState is "Resume" by default, use "-d" to set to Down.
# A "Reason" variable may be specified.
# Homepage: https://github.com/OleHolmNielsen/Slurm_tools/

# Default values
action=resume
reason="reboot and resume"
setreason=0

# Command usage:
function usage()
{
cat <<EOF
Usage:
$0 [-d] [-r <Reason>] <nodelist>
The default NextState after reboot is Resume.
Use -d to set NextState to Down.
Use -r <Reason> to specify a reason.
EOF
}


# Parse command options
while getopts "dr:h" options; do
	case $options in
		d )	action=down
			if [[ $setreason == 0 ]]
			then
				reason="reboot and down"
			fi
			;;
		r )	reason="$OPTARG"
			setreason=1
			;;
		h | * )	usage
			exit 1;;
	esac
done
shift $((OPTIND-1))
NODES="$1"

if [ $# -ne 1 ]
then
	usage
	exit 1
fi

# Check the node list
if [ "`sinfo -hN -n $NODES`" = "" ]
then
	echo "ERROR: Nodelist $NODES does not exist"
	exit 1
fi

echo "Reboot nodes $NODES with nextstate=$action and reason=$reason"
scontrol reboot asap nextstate=$action reason="$reason" $NODES 
sinfo -N -n $NODES
